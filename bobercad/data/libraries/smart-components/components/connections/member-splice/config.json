    "connections.spliceBoltLength": {
      "kind": "positiveNumber",
      "label": "Splice bolt length",
      "unit": "mm",
      "default": 70
    },
    "connections.spliceGripLength": {
      "kind": "positiveNumber",
      "label": "Splice grip length",
      "unit": "mm",
      "default": 55
    }
  },
  "presets": {
    "member-splice": {
      "id": "member-splice",
      "version": "0.1.0",
      "name": "Member splice",
      "parameters": {
        "meta": {
          "family": "member-splice"
        }
      }
    }
  },
  "ui": {
    "tabs": [
      {
        "id": "connections",
        "label": "Splice",
        "items": [
          "connections.splicePlateThickness",
          "connections.splicePlateWidth",
          "connections.splicePlateHeight",
          "connections.spliceCutGap",
          "connections.spliceFastenerRef",
          "connections.spliceHoleDiameter",
          "connections.spliceBoltLength",
          "connections.spliceGripLength"
        ]
      }
    ]
  }
