{
  "$schema": "../../../../../../../app/schemas/smart-component.schema.json",
  "type": "pan-tread",
  "kind": "stair-tread",
  "title": "Pan Tread Set",
  "version": 1,
  "roles": {
    "treadPattern": "_tread_pattern",
    "treadAssembly": "_tread_assembly"
  },
  "parameters": {
    "geometry.width": {
      "kind": "positiveNumber",
      "label": "Tread width",
      "unit": "mm",
      "default": 900
    },
    "geometry.rise": {
      "kind": "positiveNumber",
      "label": "Rise",
      "unit": "mm",
      "default": 180
    },
    "treads.thickness": {
      "kind": "positiveNumber",
      "label": "Pan thickness",
      "unit": "mm",
      "default": 8
    },
    "treads.depth": {
      "kind": "positiveNumber",
      "label": "Tread depth",
      "unit": "mm",
      "default": 280
    },
    "treads.overlap": {
      "kind": "nonNegativeNumber",
      "label": "Tread overlap",
      "unit": "mm",
      "default": 20
    },
    "treads.material": {
      "kind": "text",
      "label": "Material",
      "default": "S355"
    },
    "treads.frontLip": {
      "kind": "positiveNumber",
      "label": "Front lip",
      "unit": "mm",
      "default": 45
    },
    "treads.closedRisers": {
      "kind": "boolean",
      "label": "Closed risers",
      "default": false
    },
    "treads.finish": {
      "kind": "text",
      "label": "Finish",
      "default": "powder-coated"
    }
  },
  "presets": {
    "pan-tread": {
      "id": "pan-tread",
      "version": "0.1.0",
      "name": "Pan tread",
      "parameters": {
        "meta": {
          "family": "pan-tread"
        }
      }
    }
  },
  "ui": {
    "tabs": [
      {
        "id": "treads",
        "label": "Treads",
        "items": [
          "geometry.width",
          "geometry.rise",
          "treads.thickness",
          "treads.depth",
          "treads.overlap",
          "treads.material",
          "treads.frontLip",
          "treads.closedRisers",
          "treads.finish"
        ]
      }
    ]
  }
}
