{
  "$schema": "../../../../../../../app/schemas/smart-component.schema.json",
  "type": "folded-tray-tread",
  "kind": "stair-tread",
  "title": "Folded Tray Tread Set",
  "version": 1,
  "roles": {
    "treadPattern": "_tread_pattern",
    "treadAssembly": "_tread_assembly"
  },
  "parameters": {
    "geometry.width": {
      "kind": "positiveNumber",
      "label": "Tread width",
      "unit": "mm",
      "default": 900
    },
    "geometry.rise": {
      "kind": "positiveNumber",
      "label": "Rise",
      "unit": "mm",
      "default": 180
    },
    "treads.thickness": {
      "kind": "positiveNumber",
      "label": "Tray thickness",
      "unit": "mm",
      "default": 8
    },
    "treads.depth": {
      "kind": "positiveNumber",
      "label": "Tread depth",
      "unit": "mm",
      "default": 280
    },
    "treads.overlap": {
      "kind": "nonNegativeNumber",
      "label": "Tread overlap",
      "unit": "mm",
      "default": 20
    },
    "treads.material": {
      "kind": "text",
      "label": "Tray material",
      "default": "S355"
    },
    "treads.closedRisers": {
      "kind": "boolean",
      "label": "Closed risers",
      "default": false
    },
    "treads.finish": {
      "kind": "text",
      "label": "Tray finish",
      "default": "powder-coated"
    },
    "treads.woodThickness": {
      "kind": "positiveNumber",
      "label": "Timber thickness",
      "unit": "mm",
      "default": 32
    },
    "treads.woodNosing": {
      "kind": "nonNegativeNumber",
      "label": "Timber nosing",
      "unit": "mm",
      "default": 25
    },
    "treads.woodMaterial": {
      "kind": "text",
      "label": "Timber material",
      "default": "OAK_TIMBER"
    },
    "treads.woodFinish": {
      "kind": "text",
      "label": "Timber finish",
      "default": "clear-sealed-oak"
    }
  },
  "presets": {
    "folded-tray-tread": {
      "id": "folded-tray-tread",
      "version": "0.1.0",
      "name": "Folded tray tread",
      "parameters": {
        "meta": {
          "family": "folded-tray-tread"
        }
      }
    }
  },
  "ui": {
    "tabs": [
      {
        "id": "treads",
        "label": "Treads",
        "items": [
          "geometry.width",
          "geometry.rise",
          "treads.thickness",
          "treads.depth",
          "treads.overlap",
          "treads.material",
          "treads.closedRisers",
          "treads.finish",
          "treads.woodThickness",
          "treads.woodNosing",
          "treads.woodMaterial",
          "treads.woodFinish"
        ]
      }
    ]
  }
}
