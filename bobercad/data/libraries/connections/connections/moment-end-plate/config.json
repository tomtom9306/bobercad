      "readOnly": true
    },
    "welds.beamWeb": {
      "kind": "positiveNumber",
      "label": "Web weld",
      "unit": "mm"
    },
    "welds.beamFlanges": {
      "kind": "positiveNumber",
      "label": "Flange weld",
      "unit": "mm"
    },
    "designAssumptions.standard": {
      "kind": "text",
      "label": "Standard",
      "readOnly": true
    },
    "designAssumptions.status": {
      "kind": "text",
      "label": "Calculation",
      "readOnly": true
    },
    "loads.status": {
      "kind": "text",
      "label": "Loads",
      "readOnly": true
    }
