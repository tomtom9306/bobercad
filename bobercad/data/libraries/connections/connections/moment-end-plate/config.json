      "unit": "mm"
    },
    "plate.height": {
      "kind": "positiveNumber",
      "label": "Plate height",
      "unit": "mm"
    },
    "plate.offset": {
      "kind": "number",
      "label": "Plate offset",
      "unit": "mm"
    },
    "bolts.fastenerRef": {
      "kind": "catalogRef",
      "catalog": "fasteners",
      "label": "Fastener",
      "readOnly": true
    },
    "bolts.rows": {
      "kind": "positiveInteger",
      "label": "Rows",
      "unit": "pcs"
    },
    "bolts.columns": {
      "kind": "positiveInteger",
      "label": "Columns",
      "unit": "pcs"
    },
    "bolts.pitch": {
      "kind": "nonNegativeNumber",
      "label": "Pitch",
      "unit": "mm"
    },
    "bolts.gauge": {
      "kind": "nonNegativeNumber",
      "label": "Gauge",
      "unit": "mm"
    },
    "holes.diameter": {
      "kind": "positiveNumber",
      "label": "Hole diameter",
      "unit": "mm"
    },
    "holes.memberDepth": {
      "kind": "positiveNumber",
      "label": "Member depth",
      "unit": "mm"
    },
    "holes.type": {
      "kind": "enum",
      "values": [
        "round",
        "slotted",
        "countersunk"
      ],
