{
  "type": "fin-plate",
  "title": "Fin Plate",
  "version": 1,
  "roles": {
    "finPlate": "_fin_plate",
    "holePattern": "_bolt_grid",
    "plateHoles": "_holes_plate",
    "memberHoles": "_holes_secondary",
    "fasteners": "_bolts",
    "weld": "_support_weld",
    "beamFitting": "_beam_gap_fitting"
  },
  "requiredPlateRoles": [
    "finPlate"
  ],
  "interfaces": [
    {
      "role": "main",
      "auto": {
        "type": "planar-face",
        "faceRef": "connection-secondary-facing-section-face"
      }
    },
    {
      "role": "secondary",
      "auto": {
        "type": "member-web",
        "faceRef": "web-center-plane"
      }
    }
  ],
  "presets": {
    "beam_to_column_fin_plate_m16_1x3": {
      "id": "beam_to_column_fin_plate_m16_1x3",
      "version": "0.1.0",
      "name": "Fin plate, M16 1x3",
      "parameters": {
        "plate": {
          "thickness": 10,
          "length": 180,
          "height": 160,
          "edgeOffset": 0
        },
        "fit": {
          "beamGap": 20,
          "clipBeam": true
        },
        "bolts": {
          "fastenerRef": "M16_8_8",
          "rows": 3,
          "columns": 1,
          "pitch": 60,
          "gauge": 0,
          "length": 60,
          "parallelToSupport": false,
          "verticalPositionMode": "centered",
          "horizontalPositionMode": "centered",
          "rowSpacingMode": "equal",
          "columnSpacingMode": "equal"
        },
        "washers": {
          "head": true,
          "nut": true
        },
        "holes": {
          "diameter": 18,
          "tolerance": "normal",
          "customDiameter": 18,
          "type": "round"
        },
        "welds": {
          "front": 6,
          "back": 6,
          "top": 0,
          "bottom": 0
        },
        "designAssumptions": {
          "standard": "EN 1993-1-8",
          "status": "not-calculated"
        },
        "loads": {
          "status": "not-defined"
        }
      }
    }
  },
  "parameters": {
    "plate.thickness": {
      "kind": "positiveNumber",
      "label": "Plate thickness",
      "unit": "mm"
    },
    "plate.length": {
      "kind": "positiveNumber",
      "label": "Plate length",
      "unit": "mm"
    },
    "plate.height": {
      "kind": "positiveNumber",
      "label": "Plate height",
      "unit": "mm"
    },
    "plate.edgeOffset": {
      "kind": "nonNegativeNumber",
      "label": "Support edge",
      "unit": "mm"
    },
    "fit.beamGap": {
      "kind": "nonNegativeNumber",
      "label": "Beam gap",
      "unit": "mm",
      "required": false,
      "default": 20
    },
    "fit.clipBeam": {
      "kind": "boolean",
      "label": "Clip beam",
      "required": false,
      "default": true
    },
    "bolts.fastenerRef": {
      "kind": "catalogRef",
      "catalog": "fasteners",
      "label": "Fastener"
    },
    "bolts.rows": {
      "kind": "positiveInteger",
      "label": "Rows",
      "unit": "pcs"
    },
    "bolts.columns": {
      "kind": "positiveInteger",
      "label": "Columns",
      "unit": "pcs"
    },
    "bolts.pitch": {
      "kind": "nonNegativeNumber",
      "label": "Pitch",
      "unit": "mm"
    },
    "bolts.gauge": {
      "kind": "nonNegativeNumber",
      "label": "Gauge",
      "unit": "mm"
    },
    "bolts.verticalPositionMode": {
      "kind": "enum",
      "values": [
        "centered",
        "custom"
      ],
      "label": "Vertical position",
      "required": false,
      "default": "centered"
    },
    "bolts.horizontalPositionMode": {
      "kind": "enum",
      "values": [
        "centered",
        "custom"
      ],
      "label": "Horizontal position",
      "required": false,
      "default": "centered"
    },
    "bolts.topEdgeDistance": {
      "kind": "nonNegativeNumber",
      "label": "Top edge",
      "unit": "mm",
      "required": false,
      "derive": {
        "kind": "boltEdgeDistance",
        "sizePath": "plate.height",
        "countPath": "bolts.rows",
        "spacingModePath": "bolts.rowSpacingMode",
        "equalSpacingPath": "bolts.pitch",
        "customSpacingPath": "bolts.rowSpacings"
      }
    },
    "bolts.supportEdgeDistance": {
      "kind": "nonNegativeNumber",
      "label": "Support edge",
      "unit": "mm",
      "required": false,
      "derive": {
        "kind": "boltEdgeDistance",
        "sizePath": "plate.length",
        "countPath": "bolts.columns",
        "spacingModePath": "bolts.columnSpacingMode",
        "equalSpacingPath": "bolts.gauge",
        "customSpacingPath": "bolts.columnSpacings"
      }
    },
    "bolts.rowSpacingMode": {
      "kind": "enum",
      "values": [
        "equal",
        "custom"
      ],
      "label": "Row spacing",
      "required": false,
      "default": "equal"
    },
    "bolts.columnSpacingMode": {
      "kind": "enum",
      "values": [
        "equal",
        "custom"
      ],
      "label": "Column spacing",
      "required": false,
      "default": "equal"
    },
    "bolts.rowSpacings": {
      "kind": "numberList",
      "label": "Row gaps",
      "unit": "mm",
      "required": false,
      "itemMinimum": 0,
      "derive": {
        "kind": "spacingList",
        "countPath": "bolts.rows",
        "defaultPath": "bolts.pitch"
      }
    },
    "bolts.columnSpacings": {
      "kind": "numberList",
      "label": "Column gaps",
      "unit": "mm",
      "required": false,
      "itemMinimum": 0,
      "derive": {
        "kind": "spacingList",
        "countPath": "bolts.columns",
        "defaultPath": "bolts.gauge"
      }
    },
    "bolts.parallelToSupport": {
      "kind": "boolean",
      "label": "Bolts parallel to column",
      "required": false,
      "default": false
    },
    "bolts.length": {
      "kind": "positiveNumber",
      "label": "Bolt length",
      "unit": "mm",
      "required": false,
      "default": 60,
      "standardOptions": {
        "kind": "fastenerLengths",
        "fastenerRef": "bolts.fastenerRef"
      }
    },
    "bolts.nutPositionMode": {
      "kind": "enum",
      "values": [
        "auto",
        "custom"
      ],
      "label": "Nut position",
      "required": false,
      "default": "auto"
    },
    "bolts.nutOffset": {
      "kind": "nonNegativeNumber",
      "label": "Nut offset",
      "unit": "mm",
      "required": false,
      "default": 0
    },
    "holes.diameter": {
      "kind": "positiveNumber",
      "label": "Hole size",
      "unit": "mm",
      "readOnly": true,
      "editableWhen": {
        "path": "holes.tolerance",
        "equals": "custom"
      },
      "writePath": "holes.customDiameter",
      "derive": {
        "kind": "fastenerHoleDiameter",
        "fastenerRef": "bolts.fastenerRef",
        "tolerance": "holes.tolerance",
        "customDiameter": "holes.customDiameter",
        "fallbackDiameter": "holes.diameter"
      }
    },
    "holes.tolerance": {
      "kind": "enum",
      "values": [
        "tight",
        "normal",
        "loose",
        "custom"
      ],
      "label": "Hole tolerance",
      "required": false,
      "default": "normal"
    },
    "holes.customDiameter": {
      "kind": "positiveNumber",
      "label": "Custom hole size",
      "unit": "mm",
      "required": false,
      "default": 18
    },
    "washers.head": {
      "kind": "boolean",
      "label": "Washer under head",
      "required": false,
      "default": true
    },
    "washers.nut": {
      "kind": "boolean",
      "label": "Washer under nut",
      "required": false,
      "default": true
    },
    "holes.type": {
      "kind": "enum",
      "values": [
        "round",
        "slotted",
        "countersunk"
      ],
      "label": "Hole type",
      "readOnly": true
    },
    "welds.front": {
      "kind": "nonNegativeNumber",
      "label": "Front weld",
      "unit": "mm"
    },
    "welds.back": {
      "kind": "nonNegativeNumber",
      "label": "Back weld",
      "unit": "mm"
    },
    "welds.top": {
      "kind": "nonNegativeNumber",
      "label": "Top weld",
      "unit": "mm"
    },
    "welds.bottom": {
      "kind": "nonNegativeNumber",
      "label": "Bottom weld",
      "unit": "mm"
    },
    "designAssumptions.standard": {
      "kind": "text",
      "label": "Standard",
      "readOnly": true
    },
    "designAssumptions.status": {
      "kind": "text",
      "label": "Calculation",
      "readOnly": true
    },
    "loads.status": {
      "kind": "text",
      "label": "Loads",
      "readOnly": true
    }
  },
  "dimensions": [
    {
      "id": "plate-thickness",
      "parameter": "plate.thickness",
      "label": "t",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "finPlate",
        "axis": "normal",
        "at": {
          "localAxisY": "max",
          "localAxisZ": "max"
        },
        "offset": {
          "localAxisY": 26,
          "localAxisZ": 20
        }
      }
    },
    {
      "id": "plate-length",
      "parameter": "plate.length",
      "label": "L",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "finPlate",
        "axis": "localAxisY",
        "edgePick": "longest",
        "at": {
          "localAxisZ": "max"
        },
        "offset": {
          "localAxisZ": 28,
          "normal": 18
        }
      }
    },
    {
      "id": "plate-height",
      "parameter": "plate.height",
      "label": "H",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "finPlate",
        "axis": "localAxisZ",
        "at": {
          "localAxisY": "max"
        },
        "offset": {
          "localAxisY": 30,
          "normal": 18
        }
      }
    },
    {
      "id": "support-edge",
      "parameter": "plate.edgeOffset",
      "label": "edge",
      "reference": {
        "kind": "interface-offset",
        "interfaceRole": "main",
        "objectRole": "finPlate",
        "offset": {
          "localAxisZ": -34,
          "normal": 28
        }
      }
    },
    {
      "id": "beam-gap",
      "parameter": "fit.beamGap",
      "label": "gap",
      "reference": {
        "kind": "feature-plane-offset",
        "interfaceRole": "main",
        "featureRole": "beamFitting",
        "objectRole": "finPlate",
        "offset": {
          "localAxisZ": 46
        }
      }
    },
    {
      "id": "bolt-pattern",
      "parameter": "bolts.rows",
      "label": "bolts",
      "reference": {
        "kind": "bolt-pattern",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "rowsParameter": "bolts.rows",
        "columnsParameter": "bolts.columns",
        "offset": {
          "localAxisY": 38,
          "normal": 30
        }
      }
    },
    {
      "id": "bolt-top-edge",
      "parameter": "bolts.topEdgeDistance",
      "label": "top",
      "reference": {
        "kind": "hole-edge-distance",
        "objectRole": "finPlate",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisZ",
        "edge": "max",
        "measureBasis": "feature",
        "modeControl": {
          "path": "bolts.verticalPositionMode",
          "label": "Vertical",
          "options": [
            { "value": "centered", "label": "Centered" },
            { "value": "custom", "label": "Custom" }
          ]
        },
        "editOnCommit": {
          "bolts.verticalPositionMode": "custom"
        },
        "offset": {
          "localAxisY": -24,
          "normal": 22
        }
      }
    },
    {
      "id": "bolt-beam-top-edge",
      "parameter": "bolts.topEdgeDistance",
      "label": "beam",
      "reference": {
        "kind": "hole-interface-edge-distance",
        "objectRole": "finPlate",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "interfaceRole": "secondary",
        "axis": "localAxisZ",
        "edge": "max",
        "parameterEdge": "max",
        "measureBasis": "feature",
        "modeControl": {
          "path": "bolts.verticalPositionMode",
          "label": "Vertical",
          "options": [
            { "value": "centered", "label": "Centered" },
            { "value": "custom", "label": "Custom" }
          ]
        },
        "editOnCommit": {
          "bolts.verticalPositionMode": "custom"
        },
        "offset": {
          "localAxisY": 24,
          "normal": 20
        }
      }
    },
    {
      "id": "bolt-bottom-edge",
      "parameter": "bolts.topEdgeDistance",
      "label": "bot",
      "reference": {
        "kind": "hole-edge-distance",
        "objectRole": "finPlate",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisZ",
        "edge": "min",
        "parameterEdge": "max",
        "measureBasis": "feature",
        "modeControl": {
          "path": "bolts.verticalPositionMode",
          "label": "Vertical",
          "options": [
            { "value": "centered", "label": "Centered" },
            { "value": "custom", "label": "Custom" }
          ]
        },
        "editOnCommit": {
          "bolts.verticalPositionMode": "custom"
        },
        "offset": {
          "localAxisY": -52,
          "normal": 22
        }
      }
    },
    {
      "id": "bolt-support-edge",
      "parameter": "bolts.supportEdgeDistance",
      "label": "end",
      "reference": {
        "kind": "hole-edge-distance",
        "objectRole": "finPlate",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "interfaceRole": "main",
        "axis": "localAxisY",
        "edge": "min",
        "edgePick": "far",
        "modeControl": {
          "path": "bolts.horizontalPositionMode",
          "label": "Horizontal",
          "options": [
            { "value": "centered", "label": "Centered" },
            { "value": "custom", "label": "Custom" }
          ]
        },
        "editOnCommit": {
          "bolts.horizontalPositionMode": "custom"
        },
        "offset": {
          "localAxisZ": 34,
          "normal": 24
        }
      }
    },
    {
      "id": "bolt-pitch",
      "parameter": "bolts.pitch",
      "label": "P",
      "reference": {
        "kind": "hole-spacing",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisZ",
        "spacingModePath": "bolts.rowSpacingMode",
        "customParameter": "bolts.rowSpacings",
        "showPairSwitchers": true,
        "modeControl": {
          "path": "bolts.rowSpacingMode",
          "label": "Rows",
          "options": [
            { "value": "equal", "label": "Equal" },
            { "value": "custom", "label": "Custom" }
          ]
        },
        "pairOffset": {
          "localAxisY": 18,
          "normal": 22
        },
        "offset": {
          "localAxisY": -34,
          "normal": 24
        }
      }
    },
    {
      "id": "bolt-gauge",
      "parameter": "bolts.gauge",
      "label": "G",
      "reference": {
        "kind": "hole-spacing",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisY",
        "spacingModePath": "bolts.columnSpacingMode",
        "customParameter": "bolts.columnSpacings",
        "showPairSwitchers": true,
        "modeControl": {
          "path": "bolts.columnSpacingMode",
          "label": "Columns",
          "options": [
            { "value": "equal", "label": "Equal" },
            { "value": "custom", "label": "Custom" }
          ]
        },
        "pairOffset": {
          "localAxisZ": 22,
          "normal": 22
        },
        "offset": {
          "localAxisZ": -28,
          "normal": 24
        }
      }
    },
    {
      "id": "bolt-length",
      "parameter": "bolts.length",
      "label": "bolt",
      "reference": {
        "kind": "fastener-length",
        "fastenerRole": "fasteners",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "offset": {
          "localAxisZ": 38
        }
      }
    },
    {
      "id": "front-weld",
      "parameter": "welds.front",
      "label": "FW",
      "reference": {
        "kind": "weld-size",
        "weldRole": "weld",
        "objectRole": "finPlate",
        "interfaceRole": "main",
        "edge": "support",
        "side": "front"
      }
    },
    {
      "id": "back-weld",
      "parameter": "welds.back",
      "label": "BW",
      "reference": {
        "kind": "weld-size",
        "weldRole": "weld",
        "objectRole": "finPlate",
        "interfaceRole": "main",
        "edge": "support",
        "side": "back"
      }
    },
    {
      "id": "top-weld",
      "parameter": "welds.top",
      "label": "topW",
      "zeroLabel": "no weld",
      "reference": {
        "kind": "weld-size",
        "weldRole": "weld",
        "objectRole": "finPlate",
        "interfaceRole": "main",
        "edge": "top"
      }
    },
    {
      "id": "bottom-weld",
      "parameter": "welds.bottom",
      "label": "botW",
      "zeroLabel": "no weld",
      "reference": {
        "kind": "weld-size",
        "weldRole": "weld",
        "objectRole": "finPlate",
        "interfaceRole": "main",
        "edge": "bottom"
      }
    }
  ],
  "ui": {
    "tabs": [
      {
        "id": "parts",
        "label": "Parts",
        "items": [
          "plate.thickness",
          "plate.length",
          "plate.height",
          "plate.edgeOffset",
          "fit.beamGap",
          "fit.clipBeam",
          {
            "kind": "connectionPlates"
          }
        ]
      },
      {
        "id": "bolts",
        "label": "Bolts",
        "items": [
          "bolts.fastenerRef",
          "bolts.rows",
          "bolts.columns",
          "bolts.pitch",
          "bolts.gauge",
          "bolts.verticalPositionMode",
          {
            "kind": "parameter",
            "path": "bolts.topEdgeDistance",
            "visibleWhen": {
              "path": "bolts.verticalPositionMode",
              "equals": "custom"
            }
          },
          "bolts.horizontalPositionMode",
          {
            "kind": "parameter",
            "path": "bolts.supportEdgeDistance",
            "visibleWhen": {
              "path": "bolts.horizontalPositionMode",
              "equals": "custom"
            }
          },
          "bolts.rowSpacingMode",
          {
            "kind": "parameter",
            "path": "bolts.rowSpacings",
            "visibleWhen": {
              "all": [
                {
                  "path": "bolts.rowSpacingMode",
                  "equals": "custom"
                },
                {
                  "path": "bolts.rows",
                  "greaterThan": 1
                }
              ]
            }
          },
          "bolts.columnSpacingMode",
          {
            "kind": "parameter",
            "path": "bolts.columnSpacings",
            "visibleWhen": {
              "all": [
                {
                  "path": "bolts.columnSpacingMode",
                  "equals": "custom"
                },
                {
                  "path": "bolts.columns",
                  "greaterThan": 1
                }
              ]
            }
          },
          "bolts.parallelToSupport",
          "holes.tolerance",
          "holes.diameter",
          {
            "kind": "section",
            "label": "Fastener setup",
            "items": [
              "bolts.length",
              "washers.head",
              "washers.nut",
              "bolts.nutPositionMode",
              {
                "kind": "parameter",
                "path": "bolts.nutOffset",
                "visibleWhen": {
                  "path": "bolts.nutPositionMode",
                  "equals": "custom"
                }
              }
            ]
          }
        ]
      },
      {
        "id": "welds",
        "label": "Welds",
        "items": [
          "welds.front",
          "welds.back",
          "welds.top",
          "welds.bottom"
        ]
      },
      {
        "id": "design",
        "label": "Design",
        "items": [
          "designAssumptions.standard",
          "designAssumptions.status",
          "loads.status"
        ]
      }
    ]
  },
  "$schema": "../../../../../app/schemas/connection.schema.json"
}
