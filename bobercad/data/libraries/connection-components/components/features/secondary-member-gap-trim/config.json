{
  "type": "secondary-member-gap-trim",
  "title": "Secondary Member Gap Trim",
  "version": 1,
  "roles": {
    "beamTrimPlane": "_beam_gap_trim_plane",
    "beamTrim": "_beam_gap_trim"
  },
  "parameters": {
    "fit.beamGap": {
      "kind": "nonNegativeNumber",
      "label": "Beam gap",
      "unit": "mm",
      "required": false,
      "default": 20
    },
    "fit.clipBeam": {
      "kind": "boolean",
      "label": "Clip beam",
      "required": false,
      "default": true
    }
  },
  "dimensions": [
    {
      "id": "beam-gap",
      "parameter": "fit.beamGap",
      "label": "gap",
      "reference": {
        "kind": "trim-plane-offset",
        "interfaceRole": "main",
        "trimRole": "beamTrim",
        "objectRole": "finPlate",
        "offset": {
          "localAxisZ": 46
        }
      }
    },
    {
      "id": "beam-trim-option",
      "parameter": "fit.clipBeam",
      "label": "trim",
      "reference": {
        "kind": "trim-option-callout",
        "trimRole": "beamTrim",
        "offset": {
          "localAxisY": 42,
          "localAxisZ": 22,
          "normal": 14
        },
        "modeControl": {
          "path": "fit.clipBeam",
          "label": "Trimming",
          "options": [
            {
              "value": true,
              "label": "Clip beam"
            },
            {
              "value": false,
              "label": "No trim"
            }
          ]
        },
        "valueLabels": {
          "true": "Clip beam",
          "false": "No trim"
        }
      }
    }
  ],
  "ui": {
    "tabs": [
      {
        "id": "parts",
        "label": "Parts",
        "items": [
          "fit.beamGap",
          "fit.clipBeam"
        ]
      }
    ]
  },
  "$schema": "../../../../../../app/schemas/connection-component.schema.json"
}
