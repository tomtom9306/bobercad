{
  "type": "web-bolt-pattern",
  "title": "Web Bolt Pattern",
  "version": 1,
  "roles": {
    "holePattern": "_bolt_grid",
    "plateHoles": "_holes_plate",
    "backPlateHoles": "_back_holes_plate",
    "memberHoles": "_holes_secondary",
    "fasteners": "_bolts"
  },
  "parameters": {
    "bolts.fastenerRef": {
      "kind": "catalogRef",
      "catalog": "fasteners",
      "label": "Fastener"
    },
    "bolts.rows": {
      "kind": "positiveInteger",
      "label": "Rows",
      "unit": "pcs"
    },
    "bolts.columns": {
      "kind": "positiveInteger",
      "label": "Columns",
      "unit": "pcs"
    },
    "bolts.pitch": {
      "kind": "nonNegativeNumber",
      "label": "Pitch",
      "unit": "mm"
    },
    "bolts.gauge": {
      "kind": "nonNegativeNumber",
      "label": "Gauge",
      "unit": "mm"
    },
    "bolts.verticalPositionMode": {
      "kind": "enum",
      "values": [
        "centered",
        "custom"
      ],
      "label": "Vertical position",
      "required": false,
      "default": "centered"
    },
    "bolts.horizontalPositionMode": {
      "kind": "enum",
      "values": [
        "centered",
        "custom"
      ],
      "label": "Horizontal position",
      "required": false,
      "default": "centered"
    },
    "bolts.topEdgeDistance": {
      "kind": "nonNegativeNumber",
      "label": "Top edge",
      "unit": "mm",
      "required": false,
      "derive": {
        "kind": "boltEdgeDistance",
        "sizePath": "plate.height",
        "countPath": "bolts.rows",
        "spacingModePath": "bolts.rowSpacingMode",
        "equalSpacingPath": "bolts.pitch",
        "customSpacingPath": "bolts.rowSpacings"
      }
    },
    "bolts.supportEdgeDistance": {
      "kind": "nonNegativeNumber",
      "label": "Support edge",
      "unit": "mm",
      "required": false,
      "derive": {
        "kind": "boltEdgeDistance",
        "sizePath": "plate.length",
        "countPath": "bolts.columns",
        "spacingModePath": "bolts.columnSpacingMode",
        "equalSpacingPath": "bolts.gauge",
        "customSpacingPath": "bolts.columnSpacings"
      }
    },
    "bolts.rowSpacingMode": {
      "kind": "enum",
      "values": [
        "equal",
        "custom"
      ],
      "label": "Row spacing",
      "required": false,
      "default": "equal"
    },
    "bolts.columnSpacingMode": {
      "kind": "enum",
      "values": [
        "equal",
        "custom"
      ],
      "label": "Column spacing",
      "required": false,
      "default": "equal"
    },
    "bolts.rowSpacings": {
      "kind": "numberList",
      "label": "Row gaps",
      "unit": "mm",
      "required": false,
      "itemMinimum": 0,
      "derive": {
        "kind": "spacingList",
        "countPath": "bolts.rows",
        "defaultPath": "bolts.pitch"
      }
    },
    "bolts.columnSpacings": {
      "kind": "numberList",
      "label": "Column gaps",
      "unit": "mm",
      "required": false,
      "itemMinimum": 0,
      "derive": {
        "kind": "spacingList",
        "countPath": "bolts.columns",
        "defaultPath": "bolts.gauge"
      }
    },
    "bolts.parallelToSupport": {
      "kind": "boolean",
      "label": "Bolts parallel to column",
      "required": false,
      "default": false
    },
    "bolts.length": {
      "kind": "positiveNumber",
      "label": "Bolt length",
      "unit": "mm",
      "required": false,
      "default": 60,
      "standardOptions": {
        "kind": "fastenerLengths",
        "fastenerRef": "bolts.fastenerRef"
      }
    },
    "bolts.nutPositionMode": {
      "kind": "enum",
      "values": [
        "auto",
        "custom"
      ],
      "label": "Nut position",
      "required": false,
      "default": "auto"
    },
    "bolts.nutOffset": {
      "kind": "nonNegativeNumber",
      "label": "Nut offset",
      "unit": "mm",
      "required": false,
      "default": 0
    },
    "holes.diameter": {
      "kind": "positiveNumber",
      "label": "Hole size",
      "unit": "mm",
      "readOnly": true,
      "editableWhen": {
        "path": "holes.tolerance",
        "equals": "custom"
      },
      "writePath": "holes.customDiameter",
      "derive": {
        "kind": "fastenerHoleDiameter",
        "fastenerRef": "bolts.fastenerRef",
        "tolerance": "holes.tolerance",
        "customDiameter": "holes.customDiameter",
        "fallbackDiameter": "holes.diameter"
      }
    },
    "holes.tolerance": {
      "kind": "enum",
      "values": [
        "tight",
        "normal",
        "loose",
        "custom"
      ],
      "label": "Hole tolerance",
      "required": false,
      "default": "normal"
    },
    "holes.customDiameter": {
      "kind": "positiveNumber",
      "label": "Custom hole size",
      "unit": "mm",
      "required": false,
      "default": 18
    },
    "washers.head": {
      "kind": "boolean",
      "label": "Washer under head",
      "required": false,
      "default": true
    },
    "washers.nut": {
      "kind": "boolean",
      "label": "Washer under nut",
      "required": false,
      "default": true
    },
    "holes.type": {
      "kind": "enum",
      "values": [
        "round",
        "slotted",
        "countersunk"
      ],
      "label": "Hole type",
      "readOnly": true
    }
  },
  "dimensions": [
    {
      "id": "bolt-pattern",
      "parameter": "bolts.rows",
      "label": "bolts",
      "reference": {
        "kind": "bolt-pattern",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "rowsParameter": "bolts.rows",
        "columnsParameter": "bolts.columns",
        "offset": {
          "localAxisY": 38,
          "normal": 30
        }
      }
    },
    {
      "id": "bolt-top-edge",
      "parameter": "bolts.topEdgeDistance",
      "label": "top",
      "reference": {
        "kind": "hole-edge-distance",
        "objectRole": "finPlate",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisZ",
        "edge": "max",
        "measureBasis": "feature",
        "modeControl": {
          "path": "bolts.verticalPositionMode",
          "label": "Vertical",
          "options": [
            {
              "value": "centered",
              "label": "Centered"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        "editOnCommit": {
          "bolts.verticalPositionMode": "custom"
        },
        "offset": {
          "localAxisY": -24,
          "normal": 22
        }
      }
    },
    {
      "id": "bolt-beam-top-edge",
      "parameter": "bolts.topEdgeDistance",
      "label": "beam",
      "reference": {
        "kind": "hole-interface-edge-distance",
        "objectRole": "finPlate",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "interfaceRole": "secondary",
        "axis": "localAxisZ",
        "edge": "max",
        "parameterEdge": "max",
        "measureBasis": "feature",
        "modeControl": {
          "path": "bolts.verticalPositionMode",
          "label": "Vertical",
          "options": [
            {
              "value": "centered",
              "label": "Centered"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        "editOnCommit": {
          "bolts.verticalPositionMode": "custom"
        },
        "offset": {
          "localAxisY": 24,
          "normal": 20
        }
      }
    },
    {
      "id": "bolt-bottom-edge",
      "parameter": "bolts.topEdgeDistance",
      "label": "bot",
      "reference": {
        "kind": "hole-edge-distance",
        "objectRole": "finPlate",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisZ",
        "edge": "min",
        "parameterEdge": "max",
        "measureBasis": "feature",
        "modeControl": {
          "path": "bolts.verticalPositionMode",
          "label": "Vertical",
          "options": [
            {
              "value": "centered",
              "label": "Centered"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        "editOnCommit": {
          "bolts.verticalPositionMode": "custom"
        },
        "offset": {
          "localAxisY": -52,
          "normal": 22
        }
      }
    },
    {
      "id": "bolt-support-edge",
      "parameter": "bolts.supportEdgeDistance",
      "label": "end",
      "reference": {
        "kind": "hole-edge-distance",
        "objectRole": "finPlate",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "interfaceRole": "main",
        "axis": "localAxisY",
        "edge": "min",
        "edgePick": "far",
        "modeControl": {
          "path": "bolts.horizontalPositionMode",
          "label": "Horizontal",
          "options": [
            {
              "value": "centered",
              "label": "Centered"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        "editOnCommit": {
          "bolts.horizontalPositionMode": "custom"
        },
        "offset": {
          "localAxisZ": 34,
          "normal": 24
        }
      }
    },
    {
      "id": "bolt-pitch",
      "parameter": "bolts.pitch",
      "label": "P",
      "reference": {
        "kind": "hole-spacing",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisZ",
        "spacingModePath": "bolts.rowSpacingMode",
        "customParameter": "bolts.rowSpacings",
        "showPairSwitchers": true,
        "modeControl": {
          "path": "bolts.rowSpacingMode",
          "label": "Rows",
          "options": [
            {
              "value": "equal",
              "label": "Equal"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        "pairOffset": {
          "localAxisY": 18,
          "normal": 22
        },
        "offset": {
          "localAxisY": -34,
          "normal": 24
        }
      }
    },
    {
      "id": "bolt-gauge",
      "parameter": "bolts.gauge",
      "label": "G",
      "reference": {
        "kind": "hole-spacing",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisY",
        "spacingModePath": "bolts.columnSpacingMode",
        "customParameter": "bolts.columnSpacings",
        "showPairSwitchers": true,
        "modeControl": {
          "path": "bolts.columnSpacingMode",
          "label": "Columns",
          "options": [
            {
              "value": "equal",
              "label": "Equal"
            },
            {
              "value": "custom",
              "label": "Custom"
            }
          ]
        },
        "pairOffset": {
          "localAxisZ": 22,
          "normal": 22
        },
        "offset": {
          "localAxisZ": -28,
          "normal": 24
        }
      }
    },
    {
      "id": "bolt-length",
      "parameter": "bolts.length",
      "label": "bolt",
      "reference": {
        "kind": "fastener-length",
        "fastenerRole": "fasteners",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "offset": {
          "localAxisZ": 38
        }
      }
    }
  ],
  "ui": {
    "tabs": [
      {
        "id": "bolts",
        "label": "Bolts",
        "items": [
          "bolts.fastenerRef",
          "bolts.rows",
          "bolts.columns",
          "bolts.pitch",
          "bolts.gauge",
          "bolts.verticalPositionMode",
          {
            "kind": "parameter",
            "path": "bolts.topEdgeDistance",
            "visibleWhen": {
              "path": "bolts.verticalPositionMode",
              "equals": "custom"
            }
          },
          "bolts.horizontalPositionMode",
          {
            "kind": "parameter",
            "path": "bolts.supportEdgeDistance",
            "visibleWhen": {
              "path": "bolts.horizontalPositionMode",
              "equals": "custom"
            }
          },
          "bolts.rowSpacingMode",
          {
            "kind": "parameter",
            "path": "bolts.rowSpacings",
            "visibleWhen": {
              "all": [
                {
                  "path": "bolts.rowSpacingMode",
                  "equals": "custom"
                },
                {
                  "path": "bolts.rows",
                  "greaterThan": 1
                }
              ]
            }
          },
          "bolts.columnSpacingMode",
          {
            "kind": "parameter",
            "path": "bolts.columnSpacings",
            "visibleWhen": {
              "all": [
                {
                  "path": "bolts.columnSpacingMode",
                  "equals": "custom"
                },
                {
                  "path": "bolts.columns",
                  "greaterThan": 1
                }
              ]
            }
          },
          "bolts.parallelToSupport",
          "holes.tolerance",
          "holes.diameter",
          {
            "kind": "section",
            "label": "Fastener setup",
            "items": [
              "bolts.length",
              "washers.head",
              "washers.nut",
              "bolts.nutPositionMode",
              {
                "kind": "parameter",
                "path": "bolts.nutOffset",
                "visibleWhen": {
                  "path": "bolts.nutPositionMode",
                  "equals": "custom"
                }
              }
            ]
          }
        ]
      }
    ]
  },
  "$schema": "../../../../../../app/schemas/connection-component.schema.json"
}
