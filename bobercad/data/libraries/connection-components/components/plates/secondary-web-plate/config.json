{
  "type": "secondary-web-plate",
  "title": "Secondary Web Plate",
  "version": 1,
  "roles": {
    "finPlate": "_fin_plate",
    "backFinPlate": "_back_fin_plate"
  },
  "requiredPlateRoles": [
    "finPlate"
  ],
  "parameters": {
    "plate.thickness": {
      "kind": "positiveNumber",
      "label": "Plate thickness",
      "unit": "mm"
    },
    "plate.length": {
      "kind": "positiveNumber",
      "label": "Plate length",
      "unit": "mm"
    },
    "plate.height": {
      "kind": "positiveNumber",
      "label": "Plate height",
      "unit": "mm"
    },
    "plate.edgeOffset": {
      "kind": "nonNegativeNumber",
      "label": "Support edge",
      "unit": "mm"
    }
  },
  "components": [
    {
      "role": "backFinPlate",
      "label": "Second fin plate",
      "kind": "plate",
      "default": "ghost"
    }
  ],
  "dimensions": [
    {
      "id": "plate-thickness",
      "parameter": "plate.thickness",
      "label": "t",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "finPlate",
        "axis": "normal",
        "at": {
          "localAxisY": "max",
          "localAxisZ": "max"
        },
        "offset": {
          "localAxisY": 26,
          "localAxisZ": 20
        }
      }
    },
    {
      "id": "plate-length",
      "parameter": "plate.length",
      "label": "L",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "finPlate",
        "axis": "localAxisY",
        "edgePick": "longest",
        "at": {
          "localAxisZ": "max"
        },
        "offset": {
          "localAxisZ": 28,
          "normal": 18
        }
      }
    },
    {
      "id": "plate-height",
      "parameter": "plate.height",
      "label": "H",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "finPlate",
        "axis": "localAxisZ",
        "at": {
          "localAxisY": "max"
        },
        "offset": {
          "localAxisY": 30,
          "normal": 18
        }
      }
    },
    {
      "id": "support-edge",
      "parameter": "plate.edgeOffset",
      "label": "edge",
      "reference": {
        "kind": "interface-offset",
        "interfaceRole": "main",
        "objectRole": "finPlate",
        "offset": {
          "localAxisZ": -34,
          "normal": 28
        }
      }
    }
  ],
  "ui": {
    "tabs": [
      {
        "id": "parts",
        "label": "Parts",
        "items": [
          "plate.thickness",
          "plate.length",
          "plate.height",
          "plate.edgeOffset",
          {
            "kind": "connectionComponents",
            "roles": [
              "backFinPlate"
            ]
          }
        ]
      }
    ]
  },
  "$schema": "../../../../../../app/schemas/connection-component.schema.json"
}
