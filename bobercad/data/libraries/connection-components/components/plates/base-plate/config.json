{
  "type": "base-plate",
  "title": "Base Plate",
  "version": 1,
  "roles": {
    "basePlate": "_base_plate",
    "anchorPattern": "_anchor_grid",
    "plateHoles": "_holes_plate",
    "supportHoles": "_holes_support",
    "anchors": "_anchors",
    "weld": "_column_weld"
  },
  "requiredPlateRoles": [
    "basePlate"
  ],
  "parameters": {
    "plate.thickness": {
      "kind": "positiveNumber",
      "label": "Plate thickness",
      "unit": "mm"
    },
    "plate.width": {
      "kind": "positiveNumber",
      "label": "Plate width",
      "unit": "mm"
    },
    "plate.depth": {
      "kind": "positiveNumber",
      "label": "Plate depth",
      "unit": "mm"
    },
    "plate.offset": {
      "kind": "number",
      "label": "Plate offset",
      "unit": "mm",
      "required": false,
      "default": 0
    },
    "anchors.fastenerRef": {
      "kind": "catalogRef",
      "catalog": "fasteners",
      "label": "Anchor"
    },
    "anchors.rows": {
      "kind": "positiveInteger",
      "label": "Rows",
      "unit": "pcs"
    },
    "anchors.columns": {
      "kind": "positiveInteger",
      "label": "Columns",
      "unit": "pcs"
    },
    "anchors.pitch": {
      "kind": "nonNegativeNumber",
      "label": "Pitch",
      "unit": "mm"
    },
    "anchors.gauge": {
      "kind": "nonNegativeNumber",
      "label": "Gauge",
      "unit": "mm"
    },
    "anchors.length": {
      "kind": "positiveNumber",
      "label": "Anchor length",
      "unit": "mm",
      "required": false,
      "default": 100,
      "standardOptions": {
        "kind": "fastenerLengths",
        "fastenerRef": "anchors.fastenerRef"
      }
    },
    "holes.diameter": {
      "kind": "positiveNumber",
      "label": "Hole diameter",
      "unit": "mm"
    },
    "holes.supportDepth": {
      "kind": "positiveNumber",
      "label": "Support depth",
      "unit": "mm"
    },
    "holes.type": {
      "kind": "enum",
      "values": [
        "round",
        "slotted",
        "countersunk"
      ],
      "label": "Hole type",
      "readOnly": true
    },
    "washers.head": {
      "kind": "boolean",
      "label": "Washer under head",
      "required": false,
      "default": true
    },
    "washers.nut": {
      "kind": "boolean",
      "label": "Washer under nut",
      "required": false,
      "default": true
    },
    "welds.column": {
      "kind": "nonNegativeNumber",
      "label": "Column weld",
      "unit": "mm"
    }
  },
  "dimensions": [
    {
      "id": "base-plate-thickness",
      "parameter": "plate.thickness",
      "label": "t",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "basePlate",
        "axis": "normal",
        "at": {
          "localAxisY": "max",
          "localAxisZ": "max"
        },
        "offset": {
          "localAxisY": 24,
          "localAxisZ": 18
        }
      }
    },
    {
      "id": "base-plate-width",
      "parameter": "plate.width",
      "label": "W",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "basePlate",
        "axis": "localAxisY",
        "at": {
          "localAxisZ": "max"
        },
        "offset": {
          "localAxisZ": 28,
          "normal": 18
        }
      }
    },
    {
      "id": "base-plate-depth",
      "parameter": "plate.depth",
      "label": "D",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "basePlate",
        "axis": "localAxisZ",
        "at": {
          "localAxisY": "max"
        },
        "offset": {
          "localAxisY": 30,
          "normal": 18
        }
      }
    },
    {
      "id": "anchor-pattern",
      "parameter": "anchors.rows",
      "label": "anchors",
      "reference": {
        "kind": "bolt-pattern",
        "holePatternRole": "anchorPattern",
        "featureRole": "plateHoles",
        "rowsParameter": "anchors.rows",
        "columnsParameter": "anchors.columns",
        "offset": {
          "localAxisY": 38,
          "normal": 28
        }
      }
    }
  ],
  "ui": {
    "tabs": [
      {
        "id": "parts",
        "label": "Parts",
        "items": [
          "plate.thickness",
          "plate.width",
          "plate.depth",
          "plate.offset",
          {
            "kind": "connectionPlates"
          }
        ]
      },
      {
        "id": "bolts",
        "label": "Anchors",
        "items": [
          "anchors.fastenerRef",
          "anchors.rows",
          "anchors.columns",
          "anchors.pitch",
          "anchors.gauge",
          "anchors.length",
          "holes.diameter",
          "holes.supportDepth",
          "washers.head",
          "washers.nut"
        ]
      },
      {
        "id": "welds",
        "label": "Welds",
        "items": [
          "welds.column"
        ]
      }
    ]
  },
  "$schema": "../../../../../../app/schemas/connection-component.schema.json"
}
