        "axis": "normal",
        "at": {
          "localAxisY": "max",
          "localAxisZ": "max"
        },
        "offset": {
          "localAxisY": 24,
          "localAxisZ": 18
        }
      }
    },
    {
      "id": "end-plate-width",
      "parameter": "plate.width",
      "label": "W",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "endPlate",
        "axis": "localAxisY",
        "at": {
          "localAxisZ": "max"
        },
        "offset": {
          "localAxisZ": 28,
          "normal": 18
        }
      }
    },
    {
      "id": "end-plate-height",
      "parameter": "plate.height",
      "label": "H",
      "reference": {
        "kind": "plate-axis",
        "objectRole": "endPlate",
        "axis": "localAxisZ",
        "at": {
          "localAxisY": "min"
        },
        "offset": {
          "localAxisY": -32,
          "normal": 18
        }
      }
    },
    {
      "id": "end-plate-offset",
      "parameter": "plate.offset",
