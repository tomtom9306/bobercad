      "reference": {
        "kind": "interface-offset",
        "interfaceRole": "main",
        "objectRole": "endPlate",
        "offset": {
          "localAxisZ": -28,
          "normal": 24
        }
      }
    },
    {
      "id": "bolt-pattern",
      "parameter": "bolts.rows",
      "label": "bolts",
      "reference": {
        "kind": "bolt-pattern",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "rowsParameter": "bolts.rows",
        "columnsParameter": "bolts.columns",
        "offset": {
          "localAxisY": 38,
          "normal": 28
        }
      }
    },
    {
      "id": "bolt-pitch",
      "parameter": "bolts.pitch",
      "label": "P",
      "reference": {
        "kind": "hole-spacing",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisZ",
        "offset": {
          "localAxisY": -32,
          "normal": 22
        }
      }
    },
    {
      "id": "bolt-gauge",
      "parameter": "bolts.gauge",
      "label": "G",
      "reference": {
        "kind": "hole-spacing",
        "holePatternRole": "holePattern",
        "featureRole": "plateHoles",
        "axis": "localAxisY",
        "offset": {
          "localAxisZ": -26,
          "normal": 22
        }
      }
    }
  ],
  "ui": {
    "tabs": [
      {
        "id": "parts",
        "label": "Parts",
