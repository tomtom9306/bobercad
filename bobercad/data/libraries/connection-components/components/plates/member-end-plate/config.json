            "kind": "connectionPlates"
          }
        ]
      },
      {
        "id": "bolts",
        "label": "Bolts",
        "items": [
          "bolts.fastenerRef",
          "bolts.rows",
          "bolts.columns",
          "bolts.pitch",
          "bolts.gauge",
          "holes.diameter",
          "holes.memberDepth"
        ]
      },
      {
        "id": "welds",
        "label": "Welds",
        "items": [
          "welds.beamWeb",
          "welds.beamFlanges"
        ]
      }
    ]
  },
  "$schema": "../../../../../../app/schemas/connection-component.schema.json"
}
