{
  "type": "member-end-plate",
  "title": "Member End Plate",
  "version": 1,
  "roles": {
    "endPlate": "_end_plate",
    "holePattern": "_bolt_grid",
    "plateHoles": "_holes_plate",
    "memberHoles": "_holes_main",
    "fasteners": "_bolts",
    "weld": "_beam_weld",
    "beamFitting": "_beam_fitting"
  },
  "componentRefs": [
    "design-status"
  ],
  "parameters": {
    "plate.thickness": {
      "kind": "positiveNumber",
      "label": "Plate thickness",
      "unit": "mm"
    },
    "plate.width": {
      "kind": "positiveNumber",
      "label": "Plate width",
      "unit": "mm"
    },
    "plate.height": {
      "kind": "positiveNumber",
      "label": "Plate height",
      "unit": "mm"
    },
    "plate.offset": {
      "kind": "number",
      "label": "Plate offset",
      "unit": "mm"
    },
    "bolts.fastenerRef": {
      "kind": "catalogRef",
      "catalog": "fasteners",
      "label": "Fastener",
      "readOnly": true
    },
    "bolts.rows": {
      "kind": "positiveInteger",
      "label": "Rows",
      "unit": "pcs"
    },
    "bolts.columns": {
      "kind": "positiveInteger",
      "label": "Columns",
      "unit": "pcs"
    },
    "bolts.pitch": {
      "kind": "nonNegativeNumber",
      "label": "Pitch",
      "unit": "mm"
    },
    "bolts.gauge": {
      "kind": "nonNegativeNumber",
      "label": "Gauge",
      "unit": "mm"
    },
    "holes.diameter": {
      "kind": "positiveNumber",
      "label": "Hole diameter",
      "unit": "mm"
    },
    "holes.memberDepth": {
      "kind": "positiveNumber",
      "label": "Member depth",
      "unit": "mm"
    },
    "holes.type": {
      "kind": "enum",
      "values": [
        "round",
        "slotted",
        "countersunk"
      ],
      "label": "Hole type",
      "readOnly": true
    },
    "welds.beamWeb": {
      "kind": "positiveNumber",
      "label": "Web weld",
      "unit": "mm"
    },
    "welds.beamFlanges": {
      "kind": "positiveNumber",
      "label": "Flange weld",
      "unit": "mm"
    }
  },
  "dimensions": [
    {
      "id": "end-plate-thickness",
