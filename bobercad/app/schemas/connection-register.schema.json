{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bobercad/app/schemas/connection-register.schema.json",
  "title": "Connection Register Schema",
  "description": "Schema for the connection library register. The register is the only app-visible list of connection folders.",
  "type": "object",
  "required": ["libraryUi", "connections"],
  "properties": {
    "$schema": { "type": "string" },
    "libraryUi": { "type": "string", "pattern": "^\\./" },
    "connections": {
      "type": "array",
      "items": { "type": "string", "pattern": "^\\./" }
    }
  },
  "additionalProperties": false
}
