{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bobercad/app/schemas/api-register.schema.json",
  "title": "API Register Schema",
  "description": "Schema for the app-owned headless API register.",
  "type": "object",
  "required": ["schema", "schemaVersion", "apis"],
  "properties": {
    "$schema": { "type": "string" },
    "schema": { "type": "string" },
    "schemaVersion": { "type": "string" },
    "apis": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "module", "description"],
        "properties": {
          "id": { "type": "string" },
          "module": { "type": "string" },
          "description": { "type": "string" },
          "parameters": { "type": "object", "additionalProperties": true },
          "returns": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
