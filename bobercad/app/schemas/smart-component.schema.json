{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bobercad/app/schemas/smart-component.schema.json",
  "title": "Smart Component Definition Schema",
  "description": "Validates one Smart Component folder config.json. Components are recipe/config/build code using only the public model authoring API.",
  "type": "object",
  "required": [
    "type",
    "kind",
    "title",
    "version",
    "presets",
    "parameters",
    "ui"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "kind": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": [
        "integer",
        "string"
      ]
    },
    "recipe": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recipeStep"
      }
    },
    "interfaces": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/interface"
      }
    },
    "roles": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "requiredPlateRoles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "default": {
            "type": "string"
          },
          "objectRoles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/parameter"
      }
    },
    "dimensions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dimension"
      }
    },
    "ui": {
      "$ref": "#/$defs/ui"
    },
    "presets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/preset"
      }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "recipeStep": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "properties": {
            "operation": {
              "type": "string",
              "minLength": 1
            },
            "component": {
              "type": "string",
              "minLength": 1
            },
            "type": {
              "type": "string",
              "minLength": 1
            },
            "role": {
              "type": "string"
            },
            "input": {
              "type": "object",
              "additionalProperties": true
            },
            "inputs": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "interface": {
      "type": "object",
      "required": [
        "role"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "auto": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "parameter": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "enum": [
            "number",
            "positiveNumber",
            "nonNegativeNumber",
            "positiveInteger",
            "numberList",
            "object",
            "boolean",
            "catalogRef",
            "enum",
            "text"
          ]
        },
        "label": {
          "type": "string"
        },
        "unit": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "default": {},
        "catalog": {
          "type": "string"
        },
        "values": {
          "type": "array"
        },
        "itemMinimum": {
          "type": "number"
        },
        "itemExclusiveMinimum": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "dimension": {
      "type": "object",
      "required": [
        "id",
        "parameter",
        "reference"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "parameter": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "reference": {
          "type": "object",
          "required": [
            "kind"
          ],
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "required": [
        "tabs"
      ],
      "properties": {
        "tabs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/uiTab"
          }
        }
      },
      "additionalProperties": true
    },
    "uiTab": {
      "type": "object",
      "required": [
        "id",
        "label",
        "items"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {}
        }
      },
      "additionalProperties": true
    },
    "preset": {
      "type": "object",
      "required": [
        "id",
        "parameters"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "integer",
            "string"
          ]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
