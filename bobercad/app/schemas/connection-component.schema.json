{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bobercad/app/schemas/connection-component.schema.json",
  "title": "Connection Component Schema",
  "description": "Validates one reusable connection component config.json. Components can compose smaller components, declare parameters/dimensions/UI fragments, and build explicit project objects through the connection API.",
  "type": "object",
  "required": ["type", "title", "version"],
  "properties": {
    "$schema": { "type": "string" },
    "type": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": { "type": "string", "minLength": 1 },
    "version": { "type": ["integer", "string"] },
    "roles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "requiredPlateRoles": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "componentRefs": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentRef" }
    },
    "parameters": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/parameterSpec" }
    },
    "parameterGroups": {
      "type": "array",
      "items": { "$ref": "#/$defs/configGroup" }
    },
    "components": {
      "type": "array",
      "items": { "$ref": "#/$defs/componentToggle" }
    },
    "dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimensionSpec" }
    },
    "dimensionGroups": {
      "type": "array",
      "items": { "$ref": "#/$defs/configGroup" }
    },
    "uiGroups": {
      "type": "array",
      "items": { "$ref": "#/$defs/configGroup" }
    },
    "ui": { "$ref": "#/$defs/ui" }
  },
  "additionalProperties": true,
  "$defs": {
    "componentRef": {
      "anyOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["component"],
          "properties": {
            "component": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      ]
    },
    "parameterSpec": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": {
          "enum": [
            "number",
            "positiveNumber",
            "nonNegativeNumber",
            "positiveInteger",
            "numberList",
            "boolean",
            "catalogRef",
            "enum",
            "text"
          ]
        },
        "label": { "type": "string" },
        "unit": { "type": "string" },
        "required": { "type": "boolean" },
        "default": {},
        "readOnly": { "type": "boolean" },
        "catalog": { "type": "string" },
        "values": {
          "type": "array",
          "items": { "type": ["string", "number", "boolean"] }
        },
        "itemMinimum": { "type": "number" },
        "itemExclusiveMinimum": { "type": "number" },
        "derive": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    },
    "configGroup": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "id": { "type": "string" },
        "idPrefix": { "type": "string" },
        "label": { "type": "string" },
        "featureRole": { "type": "string" },
        "side": { "type": "string" },
        "default": {},
        "tab": { "type": "string" },
        "tabLabel": { "type": "string" }
      },
      "additionalProperties": true
    },
    "componentToggle": {
      "type": "object",
      "required": ["role", "label"],
      "properties": {
        "role": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "kind": { "type": "string" },
        "default": { "enum": ["active", "ghost"] },
        "objectRoles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": true
    },
    "dimensionSpec": {
      "type": "object",
      "required": ["id", "parameter", "reference"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "parameter": { "type": "string", "minLength": 1 },
        "label": { "type": "string" },
        "zeroLabel": { "type": "string" },
        "reference": {
          "type": "object",
          "required": ["kind"],
          "properties": { "kind": { "type": "string", "minLength": 1 } },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "ui": {
      "type": "object",
      "properties": {
        "tabs": {
          "type": "array",
          "items": { "$ref": "#/$defs/uiTab" }
        }
      },
      "additionalProperties": true
    },
    "uiTab": {
      "type": "object",
      "required": ["id", "label", "items"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "items": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string", "minLength": 1 },
              { "$ref": "#/$defs/uiItem" }
            ]
          }
        }
      },
      "additionalProperties": true
    },
    "uiItem": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "id": { "type": "string" },
        "label": { "type": "string" },
        "roles": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "items": {
          "type": "array",
          "items": {
            "anyOf": [
              { "type": "string", "minLength": 1 },
              { "$ref": "#/$defs/uiItem" }
            ]
          }
        },
        "visibleWhen": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    }
  }
}
