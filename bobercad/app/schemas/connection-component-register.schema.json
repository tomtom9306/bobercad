{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bobercad/app/schemas/connection-component-register.schema.json",
  "title": "Connection Component Register Schema",
  "description": "Schema for the reusable connection component register. The register is the only app-visible list of component folders.",
  "type": "object",
  "required": ["components"],
  "properties": {
    "$schema": { "type": "string" },
    "components": {
      "type": "array",
      "items": { "type": "string", "pattern": "^\\./" },
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
