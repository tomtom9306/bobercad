{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bobercad/app/schemas/connection.schema.json",
  "title": "Connection Definition Schema",
  "description": "Validates one modular connection folder config.json. Connection folders are recipe/config only: reusable components own roles, parameters, dimensions, UI fragments, and build code.",
  "type": "object",
  "required": [
    "type",
    "title",
    "version",
    "componentRefs",
    "recipe",
    "interfaces",
    "presets"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": [
        "integer",
        "string"
      ]
    },
    "componentRefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/componentRef"
      }
    },
    "recipe": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/componentRef"
      }
    },
    "interfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/interface"
      }
    },
    "presets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/preset"
      }
    },
    "roles": false,
    "requiredPlateRoles": false,
    "components": false,
    "parameters": false,
    "dimensions": false,
    "ui": false
  },
  "additionalProperties": true,
  "$defs": {
    "componentRef": {
      "anyOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "object",
          "required": [
            "component"
          ],
          "properties": {
            "component": {
              "type": "string",
              "minLength": 1
            },
            "input": {
              "type": "object",
              "additionalProperties": true
            },
            "inputs": {
              "type": "object",
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "interface": {
      "type": "object",
      "required": [
        "role"
      ],
      "properties": {
        "role": {
          "type": "string",
          "minLength": 1
        },
        "auto": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "minLength": 1
            },
            "faceRef": {
              "type": "string"
            },
            "memberEnd": {
              "enum": [
                "start",
                "end"
              ]
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "preset": {
      "type": "object",
      "required": [
        "id",
        "parameters"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": [
            "integer",
            "string"
          ]
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
