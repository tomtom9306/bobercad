{
  "$schema": "../../schemas/viewer-settings.schema.json",
  "schema": "steel-bim-viewer-settings",
  "schemaVersion": "0.1.0",
  "project": {
    "path": "../../../data/projects/sample_boolean_beam.json",
    "demos": {
      "boolean-beam-1": {
        "path": "../../../data/projects/sample_boolean_beam.json"
      },
      "moment-end-plate-1": {
        "path": "../../../data/projects/sample_structure.json"
      },
      "fin-plate-1": {
        "path": "../../../data/projects/sample_fin_plate.json"
      },
      "connection-test-frame-1": {
        "path": "../../../data/projects/sample_connection_test_frame.json"
      },
      "beam-to-beam-fin-plate-1": {
        "path": "../../../data/projects/sample_beam_to_beam_fin_plate.json"
      },
      "beam-to-beam-end-plate-1": {
        "path": "../../../data/projects/sample_beam_to_beam_end_plate.json"
      }
    }
  },
  "camera": {
    "home": {
      "yaw": -0.55,
      "pitch": -0.62,
      "scale": 0.04,
      "pan": [
        0,
        0
      ]
    },
    "fit": {
      "padding": 0.64,
      "minDepthHalf": 1
    }
  },
  "controls": {
    "orbitSpeed": 0.008,
    "panSpeed": 1,
    "zoomInFactor": 1.1,
    "zoomOutFactor": 0.9
  },
  "authoring": {
    "snapTolerancePx": 16,
    "defaultColumnHeight": 3000,
    "previewOpacity": 0.32,
    "beamColor": "#3f657d",
    "columnColor": "#406b85",
    "previewColor": "#2563eb",
    "snapColor": "#38bdf8",
    "workPlaneColor": "#94a3b8",
    "workPlaneSize": 280
  },
  "render": {
    "background": "#f5f7fb",
    "lighting": {
      "direction": [
        0.2,
        -0.35,
        0.9
      ],
      "ambient": 0.78,
      "diffuse": 0.25
    },
    "edges": {
      "defaultColor": "#516070",
      "plateColor": "#4b5563",
      "fastenerHeadColor": "#facc15",
      "lineWidth": 1
    },
    "dimensions": {
      "fontFamily": "Arial, sans-serif",
      "fontWeight": "400",
      "activeFontWeight": "700",
      "textHeight": 6,
      "minFontPx": 2.5,
      "surfaceLift": 0,
      "hideBehindGeometry": true,
      "tooltipDelayMs": 80,
      "tooltipFontPx": 13,
      "tooltipMaxWidthPx": 320
    },
    "axes": {
      "visible": true,
      "padding": 1.12,
      "minLength": 1200,
      "headSize": 90,
      "xColor": "#dc2626",
      "yColor": "#16a34a",
      "zColor": "#2563eb",
      "negativeColor": "#94a3b8"
    },
    "fasteners": {
      "length": 70,
      "sides": 10,
      "headRadiusFactor": 2.1
    },
    "curves": {
      "circleSegments": 32,
      "discSegments": 24
    }
  },
  "ui": {
    "showHud": true,
    "showMeta": true,
    "showResetButton": true,
    "title": "project-name"
  }
}
