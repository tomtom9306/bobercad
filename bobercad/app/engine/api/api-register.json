{
  "schema": "bobercad-api-register",
  "schemaVersion": "0.1.0",
  "apis": [
    {
      "id": "createProjectStore",
      "module": "../store/project-store.mjs",
      "description": "Create the headless project API used by UI and scripts.",
      "parameters": {
        "project": "project JSON",
        "profiles": "profile map",
        "fasteners": "fastener library",
        "smartComponentCatalog": "loaded Smart Component catalog"
      },
      "returns": "project API object"
    },
    {
      "id": "store.subscribe",
      "module": "../store/project-store.mjs",
      "description": "Listen for project changes.",
      "parameters": {
        "listener": "function(project)"
      },
      "returns": "unsubscribe function"
    },
    {
      "id": "store.project",
      "module": "../store/project-store.mjs",
      "description": "Read the current project.",
      "parameters": {},
      "returns": "project JSON"
    },
    {
      "id": "store.object",
      "module": "../store/project-store.mjs",
      "description": "Read any indexed model object.",
      "parameters": {
        "objectId": "string"
      },
      "returns": "model object"
    },
    {
      "id": "store.member",
      "module": "../store/project-store.mjs",
      "description": "Read a member by id.",
      "parameters": {
        "memberId": "string"
      },
      "returns": "member object"
    },
    {
      "id": "store.smartComponent",
      "module": "../store/project-store.mjs",
      "description": "Read a Smart Component instance by id.",
      "parameters": {
        "smartComponentId": "string"
      },
      "returns": "Smart Component instance"
    },
    {
      "id": "store.trimJoint",
      "module": "../store/project-store.mjs",
      "description": "Read a semantic corner trim joint by id.",
      "parameters": {
        "trimJointId": "string"
      },
      "returns": "trim joint object"
    },
    {
      "id": "store.smartComponentForObject",
      "module": "../store/project-store.mjs",
      "description": "Find the Smart Component that owns or references an object.",
      "parameters": {
        "objectId": "string"
      },
      "returns": "Smart Component instance or null"
    },
    {
      "id": "store.smartComponentRoot",
      "module": "../store/project-store.mjs",
      "description": "Find the highest parent Smart Component for an instance.",
      "parameters": {
        "smartComponentId": "string"
      },
      "returns": "Smart Component instance"
    },
    {
      "id": "store.smartComponentRootForObject",
      "module": "../store/project-store.mjs",
      "description": "Find the highest parent Smart Component that owns or references an object.",
      "parameters": {
        "objectId": "string"
      },
      "returns": "Smart Component instance or null"
    },
    {
      "id": "store.smartComponentObjectIds",
      "module": "../store/project-store.mjs",
      "description": "List objects owned by a Smart Component.",
      "parameters": {
        "smartComponentId": "string"
      },
      "returns": "array of object ids"
    },
    {
      "id": "store.affectedSmartComponentIds",
      "module": "../store/project-store.mjs",
      "description": "List Smart Component ids related to a member.",
      "parameters": {
        "memberId": "string"
      },
      "returns": "array of Smart Component ids"
    },
    {
      "id": "store.memberDependencyObjectIds",
      "module": "../store/project-store.mjs",
      "description": "List render/model object ids related to a member and its Smart Components.",
      "parameters": {
        "memberId": "string",
        "options": "optional filter flags such as renderableOnly or includeMember"
      },
      "returns": "array of object ids"
    },
    {
      "id": "store.featureDependencyObjectIds",
      "module": "../store/project-store.mjs",
      "description": "List render/model object ids affected by a feature edit.",
      "parameters": {
        "featureId": "string",
        "options": "optional filter flags such as renderableOnly or includeSmartComponentMembers"
      },
      "returns": "array of object ids"
    },
    {
      "id": "store.trimJointDependencyObjectIds",
      "module": "../store/project-store.mjs",
      "description": "List render/model object ids affected by a trim joint edit.",
      "parameters": {
        "trimJointId": "string",
        "options": "optional filter flags such as renderableOnly"
      },
      "returns": "array of object ids"
    },
    {
      "id": "store.definition",
      "module": "../store/project-store.mjs",
      "description": "Read the loaded definition for a connection.",
      "parameters": {
        "connectionId": "string"
      },
      "returns": "connection definition"
    },
    {
      "id": "store.supportedSmartComponents",
      "module": "../store/project-store.mjs",
      "description": "List project Smart Components supported by loaded definitions.",
      "parameters": {},
      "returns": "array of Smart Component instances"
    },
    {
      "id": "store.smartComponentPresets",
      "module": "../store/project-store.mjs",
      "description": "List available Smart Component presets.",
      "parameters": {},
      "returns": "array of presets"
    },
    {
      "id": "store.catalogEntries",
      "module": "../store/project-store.mjs",
      "description": "Read entries from a loaded project catalog, such as fasteners.",
      "parameters": {
        "catalog": "catalog id, for example fasteners"
      },
      "returns": "map of catalog entries"
    },
    {
      "id": "store.createSmartComponentFromPreset",
      "module": "../store/project-store.mjs",
      "description": "Create and generate a Smart Component from a preset.",
      "parameters": {
        "presetId": "string",
        "memberIds": "member ids or empty for standalone presets"
      },
      "returns": "project and smartComponentId"
    },
    {
      "id": "store.createTrimJoint",
      "module": "../store/project-store.mjs",
      "description": "Create a semantic trim joint with one initial trim operation.",
      "parameters": {
        "options": "memberIds, optional operationType, operationPatch, id and patch"
      },
      "returns": "project, trimJointId and trimJoint"
    },
    {
      "id": "store.deleteSmartComponent",
      "module": "../store/project-store.mjs",
      "description": "Delete a Smart Component and its generated objects.",
      "parameters": {
        "smartComponentId": "string"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.smartComponentPlateOptions",
      "module": "../store/project-store.mjs",
      "description": "List optional plates for a Smart Component.",
      "parameters": {
        "smartComponentId": "string"
      },
      "returns": "array of plate options"
    },
    {
      "id": "store.setSmartComponentPlateIncluded",
      "module": "../store/project-store.mjs",
      "description": "Toggle an optional Smart Component plate.",
      "parameters": {
        "smartComponentId": "string",
        "plateId": "string",
        "included": "boolean"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.updateSmartComponent",
      "module": "../store/project-store.mjs",
      "description": "Regenerate a Smart Component with new parameters.",
      "parameters": {
        "smartComponentId": "string",
        "parameters": "Smart Component parameter object"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.updateMember",
      "module": "../store/project-store.mjs",
      "description": "Patch a member and regenerate affected Smart Components.",
      "parameters": {
        "memberId": "string",
        "patch": "member fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.updateFeature",
      "module": "../store/project-store.mjs",
      "description": "Patch a semantic feature without changing id, owner, or type.",
      "parameters": {
        "featureId": "string",
        "patch": "feature fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.updateTrimJoint",
      "module": "../store/project-store.mjs",
      "description": "Patch a semantic corner trim joint without changing id or type.",
      "parameters": {
        "trimJointId": "string",
        "patch": "trim joint fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.updateFastenerGroup",
      "module": "../store/project-store.mjs",
      "description": "Patch a semantic fastener group through the common fastener API path, recording Smart Component overrides when applicable.",
      "parameters": {
        "fastenerGroupId": "string",
        "patch": "fastener group fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.updateTrimJointParticipant",
      "module": "../store/project-store.mjs",
      "description": "Patch one participant row in a semantic corner trim joint.",
      "parameters": {
        "trimJointId": "string",
        "memberId": "string",
        "patch": "participant fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.addTrimJointParticipant",
      "module": "../store/project-store.mjs",
      "description": "Add one member participant to a semantic corner trim joint.",
      "parameters": {
        "trimJointId": "string",
        "memberId": "string",
        "patch": "optional initial participant fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.removeTrimJointParticipant",
      "module": "../store/project-store.mjs",
      "description": "Remove one member participant from a semantic corner trim joint.",
      "parameters": {
        "trimJointId": "string",
        "memberId": "string"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.addTrimJointOperation",
      "module": "../store/project-store.mjs",
      "description": "Add one cut operation to a semantic corner trim joint.",
      "parameters": {
        "trimJointId": "string",
        "patch": "operation fields such as type, memberAId, memberAEnd, memberBId, memberBEnd, referencePlaneId, and gap"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.updateTrimJointOperation",
      "module": "../store/project-store.mjs",
      "description": "Patch one cut operation in a semantic corner trim joint.",
      "parameters": {
        "trimJointId": "string",
        "operationId": "string",
        "patch": "operation fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setTrimJointOperationMember",
      "module": "../store/project-store.mjs",
      "description": "Set member A or member B on a trim joint operation and add the member as a participant when needed.",
      "parameters": {
        "trimJointId": "string",
        "operationId": "string",
        "role": "memberA or memberB",
        "memberId": "string"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.removeTrimJointOperation",
      "module": "../store/project-store.mjs",
      "description": "Remove one cut operation from a semantic corner trim joint.",
      "parameters": {
        "trimJointId": "string",
        "operationId": "string"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setFeatureOperationEnabled",
      "module": "../store/project-store.mjs",
      "description": "Enable or disable a semantic feature operation.",
      "parameters": {
        "featureId": "string",
        "enabled": "boolean"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setReferencePlane",
      "module": "../store/project-store.mjs",
      "description": "Patch a semantic reference plane object.",
      "parameters": {
        "referencePlaneId": "string",
        "patch": "reference plane fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setFeatureBody",
      "module": "../store/project-store.mjs",
      "description": "Patch a feature cutting body object.",
      "parameters": {
        "featureId": "string",
        "patch": "body fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setFeatureSource",
      "module": "../store/project-store.mjs",
      "description": "Patch a semantic feature source object such as a member-profile cutting reference.",
      "parameters": {
        "featureId": "string",
        "patch": "source fields"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setMemberProfile",
      "module": "../store/project-store.mjs",
      "description": "Change a member profile.",
      "parameters": {
        "memberId": "string",
        "profileId": "string"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setMemberRotation",
      "module": "../store/project-store.mjs",
      "description": "Set member rotation in degrees.",
      "parameters": {
        "memberId": "string",
        "rotation": "number"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.rotateMember",
      "module": "../store/project-store.mjs",
      "description": "Add a rotation delta to a member.",
      "parameters": {
        "memberId": "string",
        "deltaDegrees": "number"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setMemberEndpoints",
      "module": "../store/project-store.mjs",
      "description": "Set member start and end points.",
      "parameters": {
        "memberId": "string",
        "start": "[x,y,z]",
        "end": "[x,y,z]"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.moveMember",
      "module": "../store/project-store.mjs",
      "description": "Move a member by a vector.",
      "parameters": {
        "memberId": "string",
        "delta": "[x,y,z]"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setMemberCenter",
      "module": "../store/project-store.mjs",
      "description": "Move a member to a target center point.",
      "parameters": {
        "memberId": "string",
        "center": "[x,y,z]"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.moveMemberWithLayout",
      "module": "../store/project-store.mjs",
      "description": "Move a member and its explicit virtual layout axis by a vector.",
      "parameters": {
        "memberId": "string",
        "delta": "[x,y,z]"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setMemberPhysicalEndpoint",
      "module": "../store/project-store.mjs",
      "description": "Move one physical member endpoint and keep a matching layout endpoint in sync.",
      "parameters": {
        "memberId": "string",
        "endpoint": "start | end",
        "point": "[x,y,z]"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.setMemberLayoutEndpoint",
      "module": "../store/project-store.mjs",
      "description": "Move one virtual layout-axis endpoint without forcing the physical member endpoint.",
      "parameters": {
        "memberId": "string",
        "endpoint": "start | end",
        "point": "[x,y,z]"
      },
      "returns": "project JSON"
    },
    {
      "id": "store.draftMemberProject",
      "module": "../store/project-store.mjs",
      "description": "Build a non-committed project draft for one member and its affected Smart Components.",
      "parameters": {
        "memberId": "string",
        "member": "complete semantic member object",
        "options": "optional flags such as regenerateSmartComponents"
      },
      "returns": "project JSON draft without mutating the store"
    },
    {
      "id": "project.memberLayoutAxis",
      "module": "./project/members.mjs",
      "description": "Read the explicit or physical fallback virtual axis for a member.",
      "parameters": {
        "member": "member object"
      },
      "returns": "layout axis start/end"
    },
    {
      "id": "project.memberAuthoringPoints",
      "module": "./project/members.mjs",
      "description": "Read center, physical endpoints, and layout endpoints used by member authoring handles.",
      "parameters": {
        "member": "member object"
      },
      "returns": "authoring point map"
    },
    {
      "id": "ctx.param",
      "module": "../modules/smart-components/smart-component-generator.mjs",
      "description": "Read a Smart Component parameter by dotted path.",
      "parameters": {
        "path": "string, for example plate.thickness"
      },
      "returns": "parameter value"
    },
    {
      "id": "ctx.optionalParam",
      "module": "../modules/smart-components/smart-component-generator.mjs",
      "description": "Read an optional Smart Component parameter by dotted path.",
      "parameters": {
        "path": "string, for example welds.top",
        "fallback": "value returned when the parameter is missing"
      },
      "returns": "parameter value or fallback"
    },
    {
      "id": "ctx.parameterValue",
      "module": "../modules/smart-components/smart-component-generator.mjs",
      "description": "Read a Smart Component parameter by dotted path, using the definition default when the instance does not store a value and emitting a diagnostic when neither exists.",
      "parameters": {
        "path": "string, for example connections.anchorLength",
        "options": "optional required, code, message and resolve diagnostic metadata"
      },
      "returns": "parameter value, definition default, or undefined after recording a diagnostic"
    },
    {
      "id": "ctx.requiredInput",
      "module": "../modules/smart-components/smart-component-generator.mjs",
      "description": "Read a child component input by dotted path and emit a diagnostic instead of silently choosing a fallback when the parent did not pass it.",
      "parameters": {
        "path": "string, for example connections.anchorLength",
        "options": "optional code, message and resolve diagnostic metadata"
      },
      "returns": "input value or undefined after recording a diagnostic"
    },
    {
      "id": "ctx.params",
      "module": "../modules/smart-components/smart-component-generator.mjs",
      "description": "Read several Smart Component parameters into a flat object.",
      "parameters": {
        "paths": "object mapping output keys to dotted parameter paths"
      },
      "returns": "object"
    },
    {
      "id": "ctx.member",
      "module": "../modules/smart-components/smart-component-generator.mjs",
      "description": "Read the resolved main or secondary Smart Component member.",
      "parameters": {
        "role": "main | secondary"
      },
      "returns": "member object"
    },
    {
      "id": "ctx.profile",
      "module": "../modules/smart-components/smart-component-generator.mjs",
      "description": "Read the profile for a Smart Component member.",
      "parameters": {
        "role": "main | secondary"
      },
      "returns": "profile object"
    },
    {
      "id": "ctx.interface",
      "module": "../modules/smart-components/smart-component-generator.mjs",
      "description": "Resolve a stored Smart Component-zone interface.",
      "parameters": {
        "role": "interface role declared by the connection definition"
      },
      "returns": "resolved interface"
    },
    {
      "id": "ctx.error",
      "module": "../modules/smart-components/smart-component-generator.mjs",
      "description": "Attach a validation diagnostic to generated output.",
      "parameters": {
        "code": "stable diagnostic code",
        "message": "human-readable issue",
        "details": "optional objectRoles and parameters arrays"
      },
      "returns": "void"
    },
    {
      "id": "ctx.geometry",
      "module": "./model/geometry.mjs",
      "description": "Geometry helpers for API consumers and Smart Component builders.",
      "parameters": {},
      "returns": "geometry helper object"
    },
    {
      "id": "ctx.geometry.rectangleOutline",
      "module": "./model/geometry.mjs",
      "description": "Create a local [y,z] rectangular plate outline.",
      "parameters": {
        "width": "number",
        "height": "number"
      },
      "returns": "outline points"
    },
    {
      "id": "ctx.geometry.clipPlateOutlineByPlane",
      "module": "./model/geometry.mjs",
      "description": "Clip a flat plate outline by a 3D plane in plate-local coordinates.",
      "parameters": {
        "outline": "array of [y,z] points",
        "plateCenter": "[x,y,z]",
        "localAxisY": "plate local y axis",
        "localAxisZ": "plate local z axis",
        "planeOrigin": "[x,y,z]",
        "planeNormal": "trim plane normal",
        "keepPoint": "optional world point on the side to keep"
      },
      "returns": "clipped outline points"
    },
    {
      "id": "ctx.geometry.plateAxes",
      "module": "./model/geometry.mjs",
      "description": "Resolve planar local axes from a web normal, beam direction, and optional preferred vertical axis.",
      "parameters": {
        "webNormal": "plate normal",
        "beamDirection": "default local y direction",
        "defaultAxisZ": "default local z direction",
        "preferredAxisZ": "optional axis to align holes or plate height"
      },
      "returns": "localAxisY and localAxisZ"
    },
    {
      "id": "ctx.geometry.linePlaneIntersection",
      "module": "./model/geometry.mjs",
      "description": "Find where a line intersects a plane, or return null when parallel.",
      "parameters": {
        "point": "point on line",
        "direction": "line direction",
        "planeOrigin": "point on plane",
        "normal": "plane normal"
      },
      "returns": "[x,y,z] or null"
    },
    {
      "id": "ctx.geometry.memberFrameAt",
      "module": "./model/geometry.mjs",
      "description": "Read a member local frame at a station for Smart Component geometry.",
      "parameters": {
        "member": "member object",
        "station": "distance from member start"
      },
      "returns": "origin, x, y and z axes"
    },
    {
      "id": "ctx.geometry.memberFrame",
      "module": "./model/geometry.mjs",
      "description": "Read a member start local frame.",
      "parameters": {
        "member": "member object"
      },
      "returns": "origin, x, y and z axes"
    },
    {
      "id": "ctx.geometry.memberLength",
      "module": "./model/geometry.mjs",
      "description": "Measure member axis length.",
      "parameters": {
        "member": "member object"
      },
      "returns": "length"
    },
    {
      "id": "ctx.geometry.sectionBounds",
      "module": "./model/geometry.mjs",
      "description": "Read profile section y/z bounds.",
      "parameters": {
        "profile": "profile object"
      },
      "returns": "minY, maxY, minZ, maxZ"
    },
    {
      "id": "ctx.geometry.sectionWebBounds",
      "module": "./model/geometry.mjs",
      "description": "Read profile web y/z bounds.",
      "parameters": {
        "profile": "profile object"
      },
      "returns": "minY, maxY, minZ, maxZ"
    },
    {
      "id": "ctx.check.requireMemberEnd",
      "module": "./model/checks.mjs",
      "description": "Require an interface to identify a member end.",
      "parameters": {
        "iface": "resolved interface",
        "message": "optional error message"
      },
      "returns": "void"
    },
    {
      "id": "ctx.check.gridFitsPlate",
      "module": "./model/checks.mjs",
      "description": "Report if a hole grid falls outside a rectangular or outlined plate.",
      "parameters": {
        "pattern": "hole pattern",
        "plateOrWidth": "plate object with outline or width number",
        "height": "number when checking a rectangle",
        "diagnostic": "code, message, objectRoles, parameters"
      },
      "returns": "void"
    },
    {
      "id": "ctx.check.plateOutlineValid",
      "module": "./model/checks.mjs",
      "description": "Report if a generated plate outline has fewer than three usable points or zero area.",
      "parameters": {
        "outline": "array of [y,z] points",
        "diagnostic": "code, message, objectRoles, parameters"
      },
      "returns": "void"
    },
    {
      "id": "ctx.check.plateFitsInterface",
      "module": "./model/checks.mjs",
      "description": "Report if a plate exceeds an interface length or height.",
      "parameters": {
        "iface": "resolved interface",
        "width": "number",
        "height": "number",
        "options": "offset and diagnostic messages"
      },
      "returns": "void"
    },
    {
      "id": "ctx.check.gridFitsInterface",
      "module": "./model/checks.mjs",
      "description": "Report if a stationed hole grid falls outside an interface.",
      "parameters": {
        "pattern": "hole pattern",
        "iface": "resolved interface",
        "options": "centerStation, code, message, objectRoles, parameters"
      },
      "returns": "void"
    },
    {
      "id": "ctx.check.gridFitsCenteredInterface",
      "module": "./model/checks.mjs",
      "description": "Report if a centered hole grid falls outside an interface.",
      "parameters": {
        "pattern": "hole pattern",
        "iface": "resolved interface",
        "options": "code, message, objectRoles, parameters"
      },
      "returns": "void"
    },
    {
      "id": "ctx.check.vectorsAligned",
      "module": "./model/checks.mjs",
      "description": "Report if two vectors are not aligned enough.",
      "parameters": {
        "a": "vector",
        "b": "vector",
        "options": "minDot, code, message, objectRoles, parameters"
      },
      "returns": "void"
    },
    {
      "id": "ctx.reference.plane",
      "module": "./model/builders.mjs",
      "description": "Create a semantic reference plane and assign it to a role.",
      "parameters": {
        "role": "role key",
        "data": "origin, normal, axisX, axisY, optional size/extents and metadata"
      },
      "returns": "reference plane object"
    },
    {
      "id": "ctx.part.plate",
      "module": "./model/builders.mjs",
      "description": "Create a semantic plate object and assign it to a role.",
      "parameters": {
        "role": "role key",
        "data": "plate fields"
      },
      "returns": "plate object"
    },
    {
