{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/profile_schema.json",
  "title": "Steel Profile Library Schema",
  "description": "Point-based profile library schema. Profile geometry is defined by closed 2D contours using [y, z] points.",
  "type": "object",
  "required": ["schema", "schemaVersion", "library", "units", "sectionCoordinateSystem", "profiles"],
  "properties": {
    "$schema": { "type": "string" },
    "schema": { "const": "steel-profile-library" },
    "schemaVersion": { "type": "string" },
    "library": {
      "type": "object",
      "required": ["id", "name", "version"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "units": {
      "type": "object",
      "required": ["length", "angle"],
      "properties": {
        "length": { "type": "string" },
        "angle": { "const": "deg" },
        "area": { "type": "string" },
        "massPerLength": { "type": "string" }
      },
      "additionalProperties": true
    },
    "sectionCoordinateSystem": {
      "type": "object",
      "required": ["pointFormat", "sectionWidthAxis", "sectionDepthAxis"],
      "properties": {
        "memberAxis": { "type": "string" },
        "pointFormat": { "const": "[y, z]" },
        "sectionWidthAxis": { "type": "string" },
        "sectionDepthAxis": { "type": "string" },
        "positiveRotation": { "type": "string" },
        "contourRule": { "type": "string" },
        "solidContourOrientation": { "const": "counter-clockwise" },
        "voidContourOrientation": { "const": "clockwise" }
      },
      "additionalProperties": true
    },
    "profiles": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/profile" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "point": {
      "type": "array",
      "prefixItems": [{ "type": "number" }, { "type": "number" }],
      "items": false
    },
    "profile": {
      "type": "object",
      "required": ["id", "designation", "profileType", "section"],
      "properties": {
        "id": { "type": "string" },
        "designation": { "type": "string" },
        "profileType": { "type": "string" },
        "section": { "$ref": "#/$defs/section" },
        "properties": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "section": {
      "type": "object",
      "required": ["type", "origin", "contours"],
      "properties": {
        "type": { "const": "polygonal-section" },
        "origin": { "type": "string" },
        "contours": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/contour" }
        },
        "referencePoints": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/point" }
        },
        "semanticRefs": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "contour": {
      "type": "object",
      "required": ["id", "role", "points"],
      "properties": {
        "id": { "type": "string" },
        "role": { "enum": ["solid", "void"] },
        "points": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/point" }
        }
      },
      "additionalProperties": true
    }
  }
}
