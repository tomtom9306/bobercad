{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schemas/frame_library_schema.json",
  "title": "Steel Frame Library Schema",
  "description": "Schema for reusable frame templates. Templates help author explicit project work points and objects but are not runtime geometry sources.",
  "type": "object",
  "required": ["schema", "schemaVersion", "library", "units", "frames"],
  "properties": {
    "$schema": { "type": "string" },
    "schema": { "const": "steel-frame-library" },
    "schemaVersion": { "type": "string" },
    "library": {
      "type": "object",
      "required": ["id", "name", "version"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "version": { "type": "string" },
        "status": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "units": {
      "type": "object",
      "required": ["length", "angle"],
      "properties": {
        "length": { "type": "string" },
        "angle": { "const": "deg" }
      },
      "additionalProperties": true
    },
    "frames": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/frameTemplate" }
    }
  },
  "additionalProperties": true,
  "$defs": {
    "vec3": {
      "type": "array",
      "prefixItems": [
        { "type": "number" },
        { "type": "number" },
        { "type": "number" }
      ],
      "items": false
    },
    "frameTemplate": {
      "type": "object",
      "required": ["id", "type", "version", "localWorkPoints", "members"],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "version": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "localWorkPoints": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/vec3" }
        },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/frameMember" }
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "parameters": {
          "type": "object",
          "additionalProperties": true
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "frameMember": {
      "type": "object",
      "required": ["role", "type", "start", "end"],
      "properties": {
        "role": { "type": "string" },
        "type": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "profile": { "type": "string" },
        "material": { "type": "string" },
        "rotation": { "type": "number" },
        "cardinalPoint": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
