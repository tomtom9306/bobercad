{
  "$schema": "../schemas/connection_library_schema.json",
  "schema": "steel-connection-library",
  "schemaVersion": "0.1.0",
  "library": {
    "id": "starter-connection-library",
    "name": "Starter Steel Connection Library",
    "version": "0.1.0",
    "status": "demo-not-certified-for-fabrication",
    "description": "Authoring presets for early steel connection modeling. Presets must create explicit project objects before viewing or export."
  },
  "units": {
    "length": "mm",
    "angle": "deg"
  },
  "connections": {
    "beam_to_column_end_plate_m16_2x4": {
      "id": "beam_to_column_end_plate_m16_2x4",
      "type": "moment-end-plate",
      "version": "0.1.0",
      "name": "Moment end plate, M16 2x4",
      "inputs": ["mainMember", "secondaryMember", "mainInterface", "secondaryInterface"],
      "parameters": {
        "plate": {
          "thickness": 12,
          "width": 170,
          "height": 390,
          "offset": 0
        },
        "bolts": {
          "fastenerRef": "M16_8_8",
          "rows": 4,
          "columns": 2,
          "pitch": 80,
          "gauge": 116
        },
        "holes": {
          "diameter": 18,
          "memberDepth": 30,
          "type": "round"
        },
        "welds": {
          "beamWeb": 6,
          "beamFlanges": 6
        },
        "stiffeners": {
          "column": {
            "enabled": false,
            "thickness": 10,
            "width": 276,
            "height": 69
          }
        },
        "chamfers": {
          "enabled": false
        },
        "designAssumptions": {
          "standard": "EN 1993-1-8",
          "status": "not-calculated"
        },
        "loads": {
          "status": "not-defined"
        }
      },
      "produces": {
        "plates": ["end-plate"],
        "features": ["hole-pattern"],
        "fastenerGroups": ["through-bolt-group"],
        "welds": ["profile-end-weld"]
      },
      "notes": "Preset provenance only. Project connection must store the actual plates, features, fastener groups, and welds."
    },
    "beam_to_column_fin_plate_m16_1x3": {
      "id": "beam_to_column_fin_plate_m16_1x3",
      "type": "fin-plate",
      "version": "0.1.0",
      "name": "Fin plate, M16 1x3",
      "inputs": ["mainMember", "secondaryMember", "mainInterface", "secondaryInterface"],
      "parameters": {
        "plate": {
          "thickness": 10,
          "length": 180,
          "height": 160,
          "edgeOffset": 0
        },
        "bolts": {
          "fastenerRef": "M16_8_8",
          "rows": 3,
          "columns": 1,
          "pitch": 60,
          "gauge": 0
        },
        "holes": {
          "diameter": 18,
          "memberDepth": 24,
          "type": "round"
        },
        "welds": {
          "support": 6
        },
        "designAssumptions": {
          "standard": "EN 1993-1-8",
          "status": "not-calculated"
        },
        "loads": {
          "status": "not-defined"
        }
      },
      "produces": {
        "plates": ["fin-plate"],
        "features": ["hole-pattern"],
        "fastenerGroups": ["through-bolt-group"],
        "welds": ["support-edge-weld"]
      },
      "notes": "Fin plate semantic preset. The same type covers column or supporting-beam configurations through explicit interfaces."
    },
    "manual_steel_to_steel_end_plate_m16_2x2": {
      "id": "manual_steel_to_steel_end_plate_m16_2x2",
      "type": "manual-steel-to-steel-end-plate",
      "version": "0.1.0",
      "name": "Manual steel-to-steel end plate, M16 2x2",
      "inputs": ["mainMember", "secondaryMember", "connectionZone"],
      "parameters": {
        "plateThickness": 10,
        "holePattern": "hole_pattern_2x2_m16",
        "fastenerRef": "M16_8_8",
        "holeDiameter": 18,
        "fastenerRows": 2,
        "fastenerColumns": 2,
        "fastenerColumnGauge": 90,
        "verticalPitch": 90
      },
      "produces": {
        "plates": ["end-plate"],
        "features": ["hole-pattern"],
        "fastenerGroups": ["through-bolt-group"]
      },
      "notes": "Used by simple portal-frame samples as provenance only."
    }
  }
}
